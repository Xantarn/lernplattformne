# Django Settings
SECRET_KEY=your-very-long-random-secret-key-generate-with-django-shell
DEBUG=False
ALLOWED_HOSTS=lernplattform.example.com,www.lernplattform.example.com,localhost
CSRF_TRUSTED_ORIGINS=https://lernplattform.example.com,https://www.lernplattform.example.com

# SSL/Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Database (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=lernplattform_db
DB_USER=lernplattform_user
DB_PASSWORD=your-very-strong-db-password
DB_HOST=localhost
DB_PORT=5432

# Optional: OCR Settings (leave as default if using Linux/Ubuntu)
# TOPIC_OCR_TESSERACT_CMD=/usr/bin/tesseract
# TOPIC_OCR_POPPLER_PATH=/usr/bin

# Code Execution (set to False if you want to disable for security)
CODE_EXECUTION_ENABLED=True
